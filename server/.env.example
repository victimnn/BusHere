# Este arquivo serve como um exemplo das variáveis de ambiente necessárias
# para rodar o projeto localmente.
#
# Instruções:
# 1. Copie este arquivo e renomeie a cópia para `.env` na raiz do projeto.
# 2. Preencha os valores para o seu ambiente de desenvolvimento local.
#    O arquivo `.env` real NÃO deve ser commitado no Git (verifique o .gitignore).
# 3. As variáveis para o ambiente de produção (Render) devem ser configuradas
#    diretamente no painel do Render.

# --- Configurações do Banco de Dados Local (Exemplo para XAMPP/MySQL) ---
# Substitua 'seu_usuario_local', 'sua_senha_local' e 'seu_nome_do_banco_local'
# pelos dados do seu banco de dados local.
# Para XAMPP com MySQL/MariaDB, os valores padrão são geralmente:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD= (geralmente vazio por padrão no XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# Nome do seu banco de dados local no XAMPP
DB_NAME=TCC

# --- URLs de Serviços/APIs ---
# URL da API local ou de desenvolvimento.
# Se você roda a API localmente, use localhost e a porta correspondente (ex: 3000, 8000, 5000).
# Se você tem um ambiente de staging ou teste no Render, pode apontar para ele.
VITE_API_URL=http://localhost:3000 # Ou a URL da sua API de desenvolvimento/staging

# --- Outras Variáveis (Exemplo) ---
# Porta que seu servidor local deve escutar (comum para Node.js/Express)
PORT=3000

# Ambiente (geralmente 'development' para local)
NODE_ENV=development

# Adicione outras variáveis que seu projeto precise aqui...
# EX: CHAVE_SECRETA_JWT=algum_valor_secreto_para_desenvolvimento

# --- Configurações de Email (SMTP) ---
# Configure estas variáveis para habilitar o envio de emails
# Se não configuradas, o sistema funcionará normalmente mas não enviará emails

# Host do servidor SMTP (ex: smtp.gmail.com, smtp.office365.com, smtp.mailtrap.io)
EMAIL_HOST=smtp.gmail.com

# Porta do servidor SMTP (587 para TLS, 465 para SSL, 25 para padrão)
EMAIL_PORT=587

# Usar conexão segura? (true para porta 465, false para outras portas)
EMAIL_SECURE=false

# Usuário/Email para autenticação SMTP
EMAIL_USER=bushereapp@gmail.com

# Senha ou senha de aplicativo para autenticação SMTP
# Para Gmail: Use "Senhas de app" (https://myaccount.google.com/apppasswords)
# Para outros provedores: Use a senha normal ou token de autenticação
EMAIL_PASS='sua_senha_aqui'

# Email que aparecerá como remetente (opcional, padrão: EMAIL_USER)
EMAIL_FROM=noreply@bushere.com

# Rejeitar certificados não autorizados? (true para produção, false para desenvolvimento)
EMAIL_TLS_REJECT_UNAUTHORIZED=false

# URL do webapp para links nos emails (usado para gerar links de convite)
WEBAPP_URL=http://localhost:5174
