{  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@web/*": ["./src/*"],
      "@mobile/*": ["../mobile/*"],
      "@server/*": ["../server/src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "src/**/*",
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
